{
    "name": "@y/hub",
    "type": "module",
    "scripts": {
        "docker:all": "docker compose up --build",
        "docker:db": "docker compose up -d --build postgres valkey minio init",
        "start:init": "node --env-file=.env --env-file-if-exists=.env.testing ./bin/init-db.js | pino-pretty -S",
        "start:server": "node --env-file .env ./bin/server.js | pino-pretty -S",
        "start:worker": "node --env-file .env ./bin/worker.js | pino-pretty -S",
        "types": "tsc --skipLibCheck",
        "lint": "npm --prefix .. exec -- eslint .",
        "format": "npm --prefix .. exec -- prettier --write .",
        "preversion": "npm run lint && npm run dist",
        "test": "node --expose-gc --max-old-space-size=8192 --env-file=.env --env-file-if-exists=.env.testing tests/index.js | pino-pretty -S -L debug",
        "debug:server": "node --env-file .env --inspect-brk ./bin/server.js | pino-pretty -S",
        "debug:worker": "node --env-file .env --inspect-brk ./bin/worker.js | pino-pretty -S",
        "debug:test": "node --expose-gc --max-old-space-size=8192 --env-file=.env --env-file-if-exists=.env.testing --inspect-brk tests/index.js | pino-pretty -S"
    },
    "bin": {
        "yhub": "./bin/yhub.js"
    },
    "files": [
        "dist/*",
        "bin/*",
        "src/*"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "default": "./src/index.js",
            "types": "./dist/src/index.d.ts"
        },
        "./plugins/s3": {
            "default": "./src/plugins/s3.js",
            "types": "./dist/src/storage/s3.d.ts"
        }
    },
    "dependencies": {
        "@y/protocols": "^1.0.6-rc.1",
        "@y/y": "^14.0.0-rc.1",
        "argon2": "^0.44.0",
        "lib0": "^1.0.0-rc.2",
        "minio": "^8.0.6",
        "pino": "^10.3.1",
        "postgres": "^3.4.3",
        "redis": "^5.10.0",
        "uws": "github:uNetworking/uWebSockets.js#v20.57.0"
    },
    "engines": {
        "npm": ">=8.0.0",
        "node": ">=22.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.6",
        "@types/ws": "^8.5.10",
        "@y/websocket": "^4.0.0-rc.0",
        "concurrently": "^8.2.2",
        "pino-pretty": "^13.1.3",
        "typescript": "^5.9.3",
        "ws": "^8.16.0",
        "y-websocket": "^2.0.4"
    }
}
