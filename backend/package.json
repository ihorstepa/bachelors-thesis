{
    "name": "@y/hub",
    "type": "module",
    "scripts": {
        "start": "docker compose --profile all up",
        "start:dbs": "docker compose --profile db up",
        "start:minio": "docker compose --profile db up minio",
        "docker:rebuild": "docker compose --profile all build --no-cache",
        "debug:server": "node --env-file .env --inspect-brk ./bin/server.js | pino-pretty -S",
        "debug:worker": "node --env-file .env --inspect-brk ./bin/worker.js | pino-pretty -S",
        "start:init": "node --env-file .env $(test -f .env.testing && echo '--env-file .env.testing') ./bin/init-db.js | pino-pretty -S",
        "dist": "npm run types",
        "types": "tsc --skipLibCheck",
        "lint": "npm --prefix .. exec eslint . && tsc --skipLibCheck",
        "format": "npm --prefix .. exec prettier --write .",
        "test": "node --expose-gc --max-old-space-size=8192 --env-file .env $(test -f .env.testing && echo '--env-file .env.testing') tests/index.js | pino-pretty -S -L debug",
        "debug:test": "node --expose-gc --max-old-space-size=8192 --env-file .env $(test -f .env.testing && echo '--env-file .env.testing') --inspect-brk tests/index.js | pino-pretty -S",
        "preversion": "npm run lint && npm run dist",
        "clean": "rm -rf **/dist "
    },
    "bin": {
        "yhub": "./bin/yhub.js"
    },
    "files": [
        "dist/*",
        "bin/*",
        "src/*"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "default": "./src/index.js",
            "types": "./dist/src/index.d.ts"
        },
        "./plugins/s3": {
            "default": "./src/plugins/s3.js",
            "types": "./dist/src/storage/s3.d.ts"
        }
    },
    "dependencies": {
        "@y/protocols": "^1.0.6-rc.1",
        "@y/y": "^14.0.0-rc.1",
        "argon2": "^0.44.0",
        "lib0": "^1.0.0-rc.2",
        "minio": "^8.0.6",
        "pino": "^10.3.1",
        "postgres": "^3.4.3",
        "redis": "^5.10.0",
        "uws": "github:uNetworking/uWebSockets.js#v20.57.0"
    },
    "engines": {
        "npm": ">=8.0.0",
        "node": ">=22.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.6",
        "@types/ws": "^8.5.10",
        "@y/websocket": "^4.0.0-rc.0",
        "concurrently": "^8.2.2",
        "pino-pretty": "^13.1.3",
        "typescript": "^5.9.3",
        "ws": "^8.16.0",
        "y-websocket": "^2.0.4"
    }
}
